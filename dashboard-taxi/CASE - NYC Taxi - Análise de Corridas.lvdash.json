{
  "datasets": [
    {
      "name": "default",
      "displayName": "Média de Passageiros por Hora",
      "queryLines": [
        "SELECT\n",
        "  num_horas,\n",
        "  des_am_pm,\n",
        "  val_media_passageiros_hora\n",
        "FROM\n",
        "  workspace.taxi.gold_media_passageiros_hora\n",
        "ORDER BY\n",
        "  num_horas"
      ]
    },
    {
      "name": "monthly_average",
      "displayName": "Média de Valor Total por Mês",
      "queryLines": [
        "SELECT\n",
        "  des_mes,\n",
        "  val_media_total_mes\n",
        "FROM\n",
        "  workspace.taxi.gold_media_valor_total_mes\n",
        "ORDER BY\n",
        "  des_mes"
      ]
    },
    {
      "name": "periodo_dia",
      "displayName": "Corridas por Período do Dia",
      "queryLines": [
        "SELECT\n",
        "  CASE\n",
        "    WHEN HOUR(tpep_pickup_datetime) BETWEEN 0 AND 5 THEN 'Madrugada'\n",
        "    WHEN HOUR(tpep_pickup_datetime) BETWEEN 6 AND 11 THEN 'Manhã'\n",
        "    WHEN HOUR(tpep_pickup_datetime) BETWEEN 12 AND 17 THEN 'Tarde'\n",
        "    ELSE 'Noite'\n",
        "  END AS des_periodo,\n",
        "  month AS des_mes,\n",
        "  COUNT(*) AS num_qtd_corridas,\n",
        "  SUM(total_amount) as val_total_periodo\n",
        "FROM\n",
        "  workspace.taxi.silver_taxi\n",
        "GROUP BY\n",
        "  des_periodo,\n",
        "  month\n",
        "ORDER BY\n",
        "  num_qtd_corridas DESC"
      ]
    },
    {
      "name": "periodo_simples",
      "displayName": "Análise por Período do Dia",
      "queryLines": [
        "SELECT\n",
        "  CASE\n",
        "    WHEN HOUR(tpep_pickup_datetime) BETWEEN 0 AND 5 THEN 'Madrugada'\n",
        "    WHEN HOUR(tpep_pickup_datetime) BETWEEN 6 AND 11 THEN 'Manhã'\n",
        "    WHEN HOUR(tpep_pickup_datetime) BETWEEN 12 AND 17 THEN 'Tarde'\n",
        "    ELSE 'Noite'\n",
        "  END AS des_periodo,\n",
        "  COUNT(*) AS num_qtd_corridas,\n",
        "  SUM(total_amount) as val_total_periodo\n",
        "FROM\n",
        "  workspace.taxi.silver_taxi\n",
        "GROUP BY\n",
        "  des_periodo\n",
        "ORDER BY\n",
        "  num_qtd_corridas DESC"
      ]
    }
  ],
